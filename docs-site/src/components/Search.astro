---
/**
 * Search.astro — overrides Starlight's Search component slot so the
 * default search button and our "Ask AI" trigger sit side-by-side in
 * the header. The Ask AI modal itself is rendered by AskAI.astro and
 * opened via window.snAskAIOpen() bound by that component's script.
 */
import Default from '@astrojs/starlight/components/Search.astro';
import AskAI from './AskAI.astro';
---

<div class="sn-askai-wrap">
  <Default><slot /></Default>
  <button type="button" class="sn-askai-trigger" data-sn-askai-trigger aria-label="Ask AI">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M2.5 12.5 4 9 1.5 7 6 6.5 8 2.5 10 6.5 14.5 7 12 9l1.5 3.5L8 11l-5.5 1.5Z" />
    </svg>
    <span class="sn-askai-label">Ask AI</span>
    <kbd>⌘I</kbd>
  </button>
</div>

<AskAI />

<script is:inline>
  document.querySelectorAll('[data-sn-askai-trigger]').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (typeof window.snAskAIOpen === 'function') window.snAskAIOpen();
    });
  });
</script>
