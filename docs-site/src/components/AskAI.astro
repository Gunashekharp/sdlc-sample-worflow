---
/**
 * AskAI.astro — Mintlify-style "Ask AI" modal.
 *
 * Triggered by the header button (rendered by Search.astro) or the ⌘+I /
 * Ctrl+I shortcut. Opens a centered modal with the chat UI. Replaces the
 * old floating bottom-right ChatWidget.
 *
 * The conversation lives in sessionStorage (per-tab) and is sent with
 * each request to the Cloudflare Worker (Claude Haiku 4.5).
 *
 * SETUP: paste your deployed Worker URL into WORKER_URL below.
 */
---

<div class="sn-askai-backdrop" hidden data-sn-askai-backdrop>
  <div class="sn-askai-modal" role="dialog" aria-modal="true" aria-labelledby="sn-askai-title">
    <header class="sn-askai-head">
      <span id="sn-askai-title">Ask the docs</span>
      <span class="sn-askai-head-actions">
        <button type="button" data-sn-askai-clear>Clear</button>
        <button type="button" class="sn-askai-close" aria-label="Close" data-sn-askai-close>&#215;</button>
      </span>
    </header>

    <div class="sn-askai-msgs" aria-live="polite" data-sn-askai-msgs></div>

    <div class="sn-askai-suggestions" hidden data-sn-askai-suggestions>
      <button class="sn-askai-suggestion" type="button" data-sn-prompt="How do I run the backend locally?">How do I run the backend locally?</button>
      <button class="sn-askai-suggestion" type="button" data-sn-prompt="What does the CI/CD adapter do?">What does the CI/CD adapter do?</button>
      <button class="sn-askai-suggestion" type="button" data-sn-prompt="How does the chat worker answer questions?">How does the chat worker answer questions?</button>
    </div>

    <form class="sn-askai-form" data-sn-askai-form>
      <input class="sn-askai-input" type="text" placeholder="Ask a question about the docs…" autocomplete="off" data-sn-askai-input />
      <button class="sn-askai-send" type="submit" data-sn-askai-send>Send</button>
    </form>
    <p class="sn-askai-note">AI-generated answers — check the linked sources.</p>
  </div>
</div>

<script is:inline>
  (() => {
    const WORKER_URL = 'https://snabbit-docs-chatbot.snabbit-docs-chatbot.workers.dev';
    const STORAGE_KEY = 'docs-chat-history';

    const backdrop = document.querySelector('[data-sn-askai-backdrop]');
    if (!backdrop) return;
    const modal = backdrop.querySelector('.sn-askai-modal');
    const msgs = backdrop.querySelector('[data-sn-askai-msgs]');
    const suggestions = backdrop.querySelector('[data-sn-askai-suggestions]');
    const form = backdrop.querySelector('[data-sn-askai-form]');
    const input = backdrop.querySelector('[data-sn-askai-input]');
    const send = backdrop.querySelector('[data-sn-askai-send]');
    const closeBtn = backdrop.querySelector('[data-sn-askai-close]');
    const clearBtn = backdrop.querySelector('[data-sn-askai-clear]');

    // Lift the modal to <body> so it floats above all Starlight chrome.
    if (backdrop.parentElement !== document.body) document.body.appendChild(backdrop);

    let history = [];
    try { history = JSON.parse(sessionStorage.getItem(STORAGE_KEY) || '[]'); } catch { history = []; }
    let busy = false;

    const save = () => { try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(history)); } catch {} };

    function bubble(role, text) {
      const el = document.createElement('div');
      el.className = 'sn-askai-msg ' + (role === 'user' ? 'sn-askai-user' : 'sn-askai-bot');
      el.textContent = text;
      msgs.appendChild(el);
      return el;
    }
    function sourcesRow(sources) {
      const row = document.createElement('div');
      row.className = 'sn-askai-sources';
      row.appendChild(document.createTextNode('Sources: '));
      sources.forEach((s, i) => {
        if (i > 0) row.appendChild(document.createTextNode(', '));
        const a = document.createElement('a');
        a.href = s.url; a.textContent = s.title || s.url;
        row.appendChild(a);
      });
      msgs.appendChild(row);
    }
    function render() {
      msgs.innerHTML = '';
      if (!history.length) {
        bubble('assistant', 'Hi! Ask me anything about the documentation.');
        if (suggestions) suggestions.removeAttribute('hidden');
      } else {
        if (suggestions) suggestions.setAttribute('hidden', '');
      }
      for (const m of history) {
        bubble(m.role, m.content);
        if (m.sources && m.sources.length) sourcesRow(m.sources);
      }
      msgs.scrollTop = msgs.scrollHeight;
    }

    async function ask(question) {
      if (busy) return;
      busy = true;
      send.disabled = true;

      const prior = history
        .filter((m) => m.role === 'user' || m.role === 'assistant')
        .slice(-6)
        .map((m) => ({ role: m.role, content: m.content }));

      history.push({ role: 'user', content: question });
      render(); save();

      const loading = bubble('assistant', 'Thinking…');
      loading.classList.add('sn-askai-loading');
      msgs.scrollTop = msgs.scrollHeight;

      if (WORKER_URL.indexOf('REPLACE') !== -1) {
        loading.remove();
        history.push({ role: 'assistant', content: 'The chatbot is not configured yet. Deploy the Worker (see chat-worker/README.md) and set WORKER_URL in AskAI.astro.' });
        render(); save(); busy = false; send.disabled = false; return;
      }

      try {
        const res = await fetch(WORKER_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question, history: prior }),
        });
        const data = await res.json();
        loading.remove();
        if (!res.ok || data.error) {
          history.push({ role: 'assistant', content: 'Sorry — something went wrong answering that. Please try again.' });
        } else {
          history.push({ role: 'assistant', content: data.answer || 'No answer was returned.', sources: Array.isArray(data.sources) ? data.sources : [] });
        }
      } catch {
        loading.remove();
        history.push({ role: 'assistant', content: 'Could not reach the chatbot. Please try again later.' });
      }

      render(); save(); busy = false; send.disabled = false;
    }

    const open = () => {
      backdrop.removeAttribute('hidden');
      setTimeout(() => input.focus(), 30);
    };
    const close = () => backdrop.setAttribute('hidden', '');

    // Expose openers to the global so Search.astro's button can call us.
    window.snAskAIOpen = open;
    window.snAskAIClose = close;

    backdrop.addEventListener('click', (e) => { if (e.target === backdrop) close(); });
    closeBtn.addEventListener('click', close);
    clearBtn.addEventListener('click', () => { history = []; save(); render(); });
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (!q) return;
      input.value = '';
      ask(q);
    });
    suggestions.addEventListener('click', (e) => {
      const t = e.target;
      if (!(t instanceof HTMLElement)) return;
      const prompt = t.getAttribute('data-sn-prompt');
      if (prompt) ask(prompt);
    });
    // Keyboard shortcut: ⌘+I or Ctrl+I
    document.addEventListener('keydown', (e) => {
      const isCmdI = (e.metaKey || e.ctrlKey) && (e.key === 'i' || e.key === 'I');
      if (isCmdI) {
        e.preventDefault();
        backdrop.hasAttribute('hidden') ? open() : close();
      }
      if (e.key === 'Escape' && !backdrop.hasAttribute('hidden')) close();
    });

    render();
  })();
</script>
