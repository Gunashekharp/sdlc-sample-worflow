---
/**
 * ChatWidget.astro — a floating "Ask the docs" chatbot.
 *
 * Rendered on every page through the Footer override (Footer.astro).
 * The conversation is kept in the browser's sessionStorage (session
 * memory): it survives page-to-page navigation and clears when the tab
 * closes. Each visitor has their own private chat.
 *
 * SETUP: after deploying the Cloudflare Worker (see chat-worker/README.md),
 * paste its URL into WORKER_URL in the <script> below.
 */
---

<div id="docs-chat">
  <button id="dc-toggle" type="button" aria-label="Ask the docs" title="Ask the docs">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
    </svg>
  </button>

  <div id="dc-panel" hidden>
    <header id="dc-head">
      <span id="dc-title">Ask the docs</span>
      <span id="dc-head-actions">
        <button id="dc-clear" type="button" title="Clear conversation">Clear</button>
        <button id="dc-close" type="button" aria-label="Close">&#215;</button>
      </span>
    </header>
    <div id="dc-msgs" aria-live="polite"></div>
    <form id="dc-form">
      <input id="dc-input" type="text" placeholder="Ask a question…" autocomplete="off" />
      <button id="dc-send" type="submit">Send</button>
    </form>
    <p id="dc-note">AI-generated answers — check the linked sources.</p>
  </div>
</div>

<style>
  #docs-chat {
    --dc-accent: var(--sl-color-accent, #3b82f6);
    --dc-bg: var(--sl-color-bg, #fff);
    --dc-text: var(--sl-color-text, #1f2937);
    --dc-border: var(--sl-color-gray-5, #d0d5dd);
    --dc-soft: var(--sl-color-gray-6, #f0f1f3);
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 999;
  }

  #dc-toggle {
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    border: none;
    background: var(--dc-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
    margin-left: auto;
  }
  #dc-toggle:hover { filter: brightness(1.08); }

  #dc-panel {
    position: absolute;
    right: 0;
    bottom: 4rem;
    width: min(23rem, calc(100vw - 2.5rem));
    height: min(32rem, calc(100vh - 7rem));
    display: flex;
    flex-direction: column;
    background: var(--dc-bg);
    color: var(--dc-text);
    border: 1px solid var(--dc-border);
    border-radius: 0.75rem;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    overflow: hidden;
  }
  #dc-panel[hidden] { display: none; }

  #dc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 0.85rem;
    background: var(--dc-accent);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
  }
  #dc-head-actions { display: flex; align-items: center; gap: 0.4rem; }
  #dc-head button {
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
    border: none;
    border-radius: 0.35rem;
    padding: 0.2rem 0.5rem;
    font-size: 0.8rem;
    cursor: pointer;
    line-height: 1.4;
  }
  #dc-head button:hover { background: rgba(255, 255, 255, 0.32); }
  #dc-close { font-size: 1rem; padding: 0.05rem 0.45rem; }

  #dc-msgs {
    flex: 1;
    overflow-y: auto;
    padding: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .dc-msg {
    max-width: 85%;
    padding: 0.5rem 0.7rem;
    border-radius: 0.65rem;
    white-space: pre-wrap;
    word-wrap: break-word;
  }
  .dc-user {
    align-self: flex-end;
    background: var(--dc-accent);
    color: #fff;
    border-bottom-right-radius: 0.15rem;
  }
  .dc-bot {
    align-self: flex-start;
    background: var(--dc-soft);
    color: var(--dc-text);
    border-bottom-left-radius: 0.15rem;
  }
  .dc-loading { opacity: 0.7; font-style: italic; }
  .dc-sources {
    align-self: flex-start;
    font-size: 0.78rem;
    opacity: 0.85;
    margin-top: -0.25rem;
  }
  .dc-sources a { color: var(--dc-accent); }

  #dc-form {
    display: flex;
    gap: 0.4rem;
    padding: 0.6rem;
    border-top: 1px solid var(--dc-border);
  }
  #dc-input {
    flex: 1;
    padding: 0.45rem 0.6rem;
    border: 1px solid var(--dc-border);
    border-radius: 0.45rem;
    background: var(--dc-bg);
    color: var(--dc-text);
    font-size: 0.9rem;
  }
  #dc-send {
    background: var(--dc-accent);
    color: #fff;
    border: none;
    border-radius: 0.45rem;
    padding: 0 0.85rem;
    font-size: 0.88rem;
    cursor: pointer;
  }
  #dc-send:disabled { opacity: 0.55; cursor: default; }

  #dc-note {
    margin: 0;
    padding: 0 0.7rem 0.55rem;
    font-size: 0.7rem;
    opacity: 0.6;
    text-align: center;
  }
</style>

<script>
  // ---------------------------------------------------------------------
  // SETUP: paste your deployed Cloudflare Worker URL here.
  const WORKER_URL = 'https://REPLACE-WITH-YOUR-WORKER-URL.workers.dev';
  // ---------------------------------------------------------------------

  const STORAGE_KEY = 'docs-chat-history';
  const $ = (id) => document.getElementById(id);

  const toggle = $('dc-toggle');
  const panel = $('dc-panel');
  const closeBtn = $('dc-close');
  const clearBtn = $('dc-clear');
  const form = $('dc-form');
  const input = $('dc-input');
  const sendBtn = $('dc-send');
  const msgs = $('dc-msgs');

  if (toggle && panel && form && input && msgs) {
    // Starlight renders the footer inside a nested stacking context that
    // sits below the right ("On this page") sidebar. That sidebar would
    // otherwise overlap the floating button and swallow real clicks, even
    // though the button is painted on top. Lift the whole widget to
    // <body> so it floats above all page chrome and stays clickable.
    const root = $('docs-chat');
    if (root && root.parentElement !== document.body) {
      document.body.appendChild(root);
    }

    let history = [];
    try {
      history = JSON.parse(sessionStorage.getItem(STORAGE_KEY) || '[]');
    } catch (e) {
      history = [];
    }
    let busy = false;

    const save = () => {
      try {
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify(history));
      } catch (e) {
        /* sessionStorage unavailable — chat still works for this page */
      }
    };

    function bubble(role, text) {
      const el = document.createElement('div');
      el.className = 'dc-msg ' + (role === 'user' ? 'dc-user' : 'dc-bot');
      el.textContent = text;
      msgs.appendChild(el);
      return el;
    }

    function sourcesRow(sources) {
      const row = document.createElement('div');
      row.className = 'dc-sources';
      row.appendChild(document.createTextNode('Sources: '));
      sources.forEach((s, i) => {
        if (i > 0) row.appendChild(document.createTextNode(', '));
        const a = document.createElement('a');
        a.href = s.url;
        a.textContent = s.title || s.url;
        row.appendChild(a);
      });
      msgs.appendChild(row);
    }

    function render() {
      msgs.innerHTML = '';
      if (!history.length) {
        bubble('assistant', 'Hi! Ask me anything about the documentation.');
      }
      for (const m of history) {
        bubble(m.role, m.content);
        if (m.sources && m.sources.length) sourcesRow(m.sources);
      }
      msgs.scrollTop = msgs.scrollHeight;
    }

    async function ask(question) {
      if (busy) return;
      busy = true;
      sendBtn.disabled = true;

      // Recent turns BEFORE this question — the Worker adds the question itself.
      const priorTurns = history
        .filter((m) => m.role === 'user' || m.role === 'assistant')
        .slice(-6)
        .map((m) => ({ role: m.role, content: m.content }));

      history.push({ role: 'user', content: question });
      render();
      save();

      const loading = bubble('assistant', 'Thinking…');
      loading.classList.add('dc-loading');
      msgs.scrollTop = msgs.scrollHeight;

      if (WORKER_URL.indexOf('REPLACE') !== -1) {
        loading.remove();
        history.push({
          role: 'assistant',
          content:
            'The chatbot is not configured yet. Deploy the Worker (see chat-worker/README.md) and set WORKER_URL in ChatWidget.astro.',
        });
        render();
        save();
        busy = false;
        sendBtn.disabled = false;
        return;
      }

      try {
        const res = await fetch(WORKER_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question, history: priorTurns }),
        });
        const data = await res.json();
        loading.remove();
        if (!res.ok || data.error) {
          history.push({
            role: 'assistant',
            content: 'Sorry — something went wrong answering that. Please try again.',
          });
        } else {
          history.push({
            role: 'assistant',
            content: data.answer || 'No answer was returned.',
            sources: Array.isArray(data.sources) ? data.sources : [],
          });
        }
      } catch (e) {
        loading.remove();
        history.push({
          role: 'assistant',
          content: 'Could not reach the chatbot. Please try again later.',
        });
      }

      render();
      save();
      busy = false;
      sendBtn.disabled = false;
    }

    toggle.addEventListener('click', () => {
      if (panel.hasAttribute('hidden')) {
        panel.removeAttribute('hidden');
        input.focus();
      } else {
        panel.setAttribute('hidden', '');
      }
    });
    closeBtn.addEventListener('click', () => panel.setAttribute('hidden', ''));
    clearBtn.addEventListener('click', () => {
      history = [];
      save();
      render();
    });
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (!q) return;
      input.value = '';
      ask(q);
    });

    render();
  }
</script>
