---
/**
 * ContextualMenu.astro — Mintlify-style page-header dropdown for copying
 * the current page as Markdown or handing it off to ChatGPT / Claude /
 * Perplexity / Cursor with the page already loaded as context. The page
 * itself is served as plain Markdown by src/pages/[...slug].md.ts.
 */
---

<div class="sn-cmenu" data-sn-cmenu>
  <button type="button" class="sn-cmenu-toggle" aria-haspopup="menu" aria-expanded="false" data-sn-cmenu-toggle>
    <span>Copy page</span>
    <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 4.5 6 7.5 9 4.5" />
    </svg>
  </button>

  <div class="sn-cmenu-panel" role="menu" hidden data-sn-cmenu-panel>
    <div class="sn-cmenu-section-label">This page</div>

    <button type="button" class="sn-cmenu-item" role="menuitem" data-sn-action="copy">
      <svg class="sn-cmenu-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="4" y="4" width="9" height="10" rx="1.5" />
        <path d="M3 11V3a1.5 1.5 0 0 1 1.5-1.5H11" />
      </svg>
      <span>Copy page as Markdown</span>
    </button>

    <a class="sn-cmenu-item" role="menuitem" data-sn-action="view-md" href="#" target="_blank" rel="noopener">
      <svg class="sn-cmenu-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 2.5h7L13 5v8.5a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-10a1 1 0 0 1 1-1Z" />
        <path d="M10 2.5V5h3" />
      </svg>
      <span>View as Markdown</span>
    </a>

    <div class="sn-cmenu-divider"></div>
    <div class="sn-cmenu-section-label">Open with AI</div>

    <a class="sn-cmenu-item" role="menuitem" data-sn-action="ai-chatgpt" href="#" target="_blank" rel="noopener">
      <svg class="sn-cmenu-icon" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13Zm0 1.25a5.25 5.25 0 1 1 0 10.5 5.25 5.25 0 0 1 0-10.5Zm-.5 2.5h1V8h2v1h-2v2.25h-1V9h-2V8h2V5.25Z" />
      </svg>
      <span>Open in ChatGPT</span>
    </a>

    <a class="sn-cmenu-item" role="menuitem" data-sn-action="ai-claude" href="#" target="_blank" rel="noopener">
      <svg class="sn-cmenu-icon" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M3.5 11.5 6 4h1.4l2.5 7.5H8.5L8 9.8H5.4l-.5 1.7H3.5Zm2.3-3h1.9L6.75 5.85 5.8 8.5Zm6.7 3V4H14v7.5h-1.5Z" />
      </svg>
      <span>Open in Claude</span>
    </a>

    <a class="sn-cmenu-item" role="menuitem" data-sn-action="ai-perplexity" href="#" target="_blank" rel="noopener">
      <svg class="sn-cmenu-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="8" cy="8" r="6" />
        <path d="M8 5v3l2 1.5" />
      </svg>
      <span>Ask Perplexity</span>
    </a>

    <a class="sn-cmenu-item" role="menuitem" data-sn-action="ai-cursor" href="#" target="_blank" rel="noopener">
      <svg class="sn-cmenu-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m2.5 2.5 11 5.5-5 1.5-1.5 5-4.5-12Z" />
      </svg>
      <span>Open in Cursor</span>
    </a>
  </div>
</div>

<script is:inline>
  (() => {
    document.querySelectorAll('[data-sn-cmenu]').forEach(bind);
    function bind(menu) {
      if (menu.dataset.snBound) return;
      menu.dataset.snBound = '1';
      const toggle = menu.querySelector('[data-sn-cmenu-toggle]');
      const panel = menu.querySelector('[data-sn-cmenu-panel]');
      if (!toggle || !panel) return;
      const close = () => { panel.setAttribute('hidden', ''); toggle.setAttribute('aria-expanded', 'false'); };
      const open = () => { panel.removeAttribute('hidden'); toggle.setAttribute('aria-expanded', 'true'); };
      toggle.addEventListener('click', (e) => { e.stopPropagation(); panel.hasAttribute('hidden') ? open() : close(); });
      document.addEventListener('click', (e) => { if (!menu.contains(e.target)) close(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
      const mdUrl = () => {
        const u = new URL(window.location.href);
        let pathname = u.pathname.replace(/\/$/, '');
        if (!pathname) pathname = '/';
        return u.origin + pathname + '.md';
      };
      menu.querySelector('[data-sn-action="copy"]').addEventListener('click', async () => {
        try { const r = await fetch(mdUrl()); if (!r.ok) throw 0; await navigator.clipboard.writeText(await r.text()); flashToggle('Copied'); }
        catch { flashToggle('Copy failed'); }
        close();
      });
      const viewMd = menu.querySelector('[data-sn-action="view-md"]');
      viewMd.addEventListener('mousedown', () => { viewMd.href = mdUrl(); });
      viewMd.addEventListener('click', () => close());
      const bindAI = (sel, builder) => {
        const a = menu.querySelector(sel);
        a.addEventListener('mousedown', () => { a.href = builder(mdUrl()); });
        a.addEventListener('click', () => close());
      };
      bindAI('[data-sn-action="ai-chatgpt"]', (u) => `https://chat.openai.com/?q=${encodeURIComponent(`Read this documentation page and help me with questions about it: ${u}`)}`);
      bindAI('[data-sn-action="ai-claude"]', (u) => `https://claude.ai/new?q=${encodeURIComponent(`Read this documentation page and help me with questions about it: ${u}`)}`);
      bindAI('[data-sn-action="ai-perplexity"]', (u) => `https://www.perplexity.ai/search?q=${encodeURIComponent(`Read ${u} and help me with questions about the Snabbit Agent Console.`)}`);
      bindAI('[data-sn-action="ai-cursor"]', (u) => `cursor://anysphere.cursor-deeplink/prompt?text=${encodeURIComponent(`Use ${u} as context for this conversation.`)}`);
      function flashToggle(t) { const l = toggle.querySelector('span'); if (!l) return; const p = l.textContent; l.textContent = t; setTimeout(() => { l.textContent = p; }, 1400); }
    }
  })();
</script>
